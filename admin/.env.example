# Base URL of the sports-calendar Go backend (auth, catalog, ICS, ...).
VITE_API_BASE_URL=http://localhost:8080

# Base URL of the sports-spider (Transfermarkt crawler) FastAPI backend, used by
# the "Crawler" page. Local compose stack exposes it on 127.0.0.1:8001.
# Online: set to the public cloudflared subdomain, e.g.
#   VITE_SPIDER_API_BASE_URL=https://spider-api.sports-calendar.com
VITE_SPIDER_API_BASE_URL=http://localhost:8001
